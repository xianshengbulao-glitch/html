<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>八维量化雷达 V5.2 - 完整剔骨筛选系统</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            background: #0a0a0a;
            color: #e0e0e0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "JetBrains Mono", monospace;
            line-height: 1.6;
            padding: 20px;
        }
        
        .container { max-width: 1200px; margin: 0 auto; }
        
        /* Header */
        .header {
            background: rgba(20,20,20,0.95);
            border-bottom: 1px solid #333;
            padding: 20px;
            margin: -20px -20px 30px -20px;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(10px);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .title {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: 2px;
        }
        
        .title span { color: #666; font-size: 16px; }
        
        .mode-btns { display: flex; gap: 10px; }
        
        .mode-btn {
            padding: 8px 16px;
            border: 1px solid #333;
            background: #1a1a1a;
            color: #888;
            cursor: pointer;
            border-radius: 6px;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        .mode-btn.active {
            background: rgba(0,212,255,0.1);
            border-color: #00d4ff;
            color: #00d4ff;
        }
        
        /* Cards */
        .card {
            background: #141414;
            border: 1px solid #2a2a2a;
            border-left: 4px solid #444;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 16px;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .card:hover {
            transform: translateX(5px);
            border-color: #444;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }
        
        .card.kill { border-left-color: #ff0040; background: rgba(255,0,64,0.05); }
        .card.pass { border-left-color: #00ff88; background: rgba(0,255,136,0.05); }
        .card.warn { border-left-color: #ffaa00; background: rgba(255,170,0,0.05); }
        .card.info { border-left-color: #00d4ff; background: rgba(0,212,255,0.05); }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            pointer-events: none;
        }
        
        .card-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
            pointer-events: none;
        }
        
        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }
        
        .badge-kill { background: rgba(255,0,64,0.2); color: #ff0040; border: 1px solid rgba(255,0,64,0.4); }
        .badge-pass { background: rgba(0,255,136,0.2); color: #00ff88; border: 1px solid rgba(0,255,136,0.4); }
        .badge-warn { background: rgba(255,170,0,0.2); color: #ffaa00; border: 1px solid rgba(255,170,0,0.4); }
        
        .tag {
            display: inline-block;
            padding: 2px 6px;
            background: #2a2a2a;
            color: #888;
            font-size: 11px;
            border-radius: 4px;
            font-weight: bold;
        }
        
        .tag.red { background: rgba(255,0,64,0.2); color: #ff6b6b; }
        .tag.orange { background: rgba(255,170,0,0.2); color: #ffaa00; }
        .tag.green { background: rgba(0,255,136,0.2); color: #00ff88; }
        .tag.blue { background: rgba(0,212,255,0.2); color: #00d4ff; }
        
        /* Content */
        .card-content {
            font-size: 14px;
            color: #888;
            margin-top: 10px;
            pointer-events: none;
        }
        
        .card-content strong { color: #ccc; }
        
        .detail {
            display: none;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #2a2a2a;
            font-size: 13px;
            color: #666;
            line-height: 1.8;
            animation: fadeIn 0.3s;
        }
        
        .detail.show { display: block; }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .arrow {
            width: 20px;
            height: 20px;
            color: #666;
            transition: transform 0.3s;
            flex-shrink: 0;
            margin-left: 10px;
        }
        
        .arrow.rotate { transform: rotate(180deg); }
        
        /* Anchor Section */
        .anchor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }
        
        .anchor-box {
            background: #0f0f0f;
            border: 1px solid #333;
            padding: 15px;
            border-radius: 6px;
        }
        
        .anchor-box.red { border-color: rgba(255,0,64,0.4); background: rgba(255,0,64,0.05); }
        .anchor-box.green { border-color: rgba(0,255,136,0.4); background: rgba(0,255,136,0.05); }
        .anchor-box.blue { border-color: rgba(0,212,255,0.4); background: rgba(0,212,255,0.05); }
        
        .anchor-label { font-size: 12px; color: #666; margin-bottom: 5px; }
        .anchor-value { font-size: 24px; font-weight: bold; font-family: monospace; }
        .anchor-value.red { color: #ff0040; }
        .anchor-value.green { color: #00ff88; }
        .anchor-value.blue { color: #00d4ff; }
        
        input[type="number"] {
            width: 100%;
            background: #0f0f0f;
            border: 1px solid #333;
            color: #00d4ff;
            padding: 10px;
            border-radius: 6px;
            font-size: 18px;
            font-family: monospace;
            outline: none;
        }
        
        input[type="number"]:focus { border-color: #00d4ff; }
        
        /* Grids */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; }
        
        @media (max-width: 768px) {
            .grid-2, .grid-3 { grid-template-columns: 1fr; }
            .header { flex-direction: column; gap: 15px; align-items: flex-start; }
        }
        
        /* Notice */
        .notice {
            background: rgba(0,212,255,0.1);
            border: 1px solid rgba(0,212,255,0.3);
            padding: 15px;
            border-radius: 6px;
            margin-top: 20px;
            display: none;
        }
        
        .notice.show { display: block; }
        
        /* Score section */
        .score-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .score-item {
            background: #0f0f0f;
            border: 1px solid #2a2a2a;
            padding: 12px;
            border-radius: 6px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .must { color: #ff0040; font-size: 12px; font-weight: bold; }
        .can-zero { color: #ffaa00; font-size: 12px; font-weight: bold; }
        
        .section-title {
            font-size: 18px;
            font-weight: bold;
            margin: 40px 0 20px 0;
            padding-bottom: 10px;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .small { font-size: 12px; color: #666; font-weight: normal; }
        
        .highlight {
            background: rgba(255,170,0,0.1);
            border-left: 3px solid #ffaa00;
            padding: 10px;
            margin: 10px 0;
            border-radius: 0 4px 4px 0;
        }
        
        .highlight.green {
            background: rgba(0,255,136,0.1);
            border-left-color: #00ff88;
        }
        
        .highlight.red {
            background: rgba(255,0,64,0.1);
            border-left-color: #ff0040;
        }
        
        .highlight.blue {
            background: rgba(0,212,255,0.1);
            border-left-color: #00d4ff;
        }
        
        /* Output cards */
        .output-card {
            padding: 20px;
            border-radius: 8px;
            border: 1px solid;
        }
        
        .output-card.green { background: rgba(0,255,136,0.05); border-color: rgba(0,255,136,0.3); }
        .output-card.blue { background: rgba(0,212,255,0.05); border-color: rgba(0,212,255,0.3); }
        .output-card.orange { background: rgba(255,170,0,0.05); border-color: rgba(255,170,0,0.3); }
        
        .output-title { font-weight: bold; margin-bottom: 10px; display: flex; justify-content: space-between; }
        
        footer {
            margin-top: 50px;
            padding-top: 20px;
            border-top: 1px solid #333;
            text-align: center;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="container">
        
        <!-- Header -->
        <div class="header">
            <div>
                <div class="title">八维量化雷达 <span>V5.2</span></div>
                <div style="font-size: 12px; color: #666; margin-top: 5px;">十层剔骨阵 · 生存与进攻平衡版</div>
            </div>
            <div class="mode-btns">
                <button class="mode-btn active" onclick="setMode('normal')">常规模式</button>
                <button class="mode-btn" onclick="setMode('war')">战时模式</button>
            </div>
        </div>

        <!-- Price Anchor -->
        <div class="card info" onclick="toggle('anchor-detail', 'anchor-arrow')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag blue">价格锚点</span>
                        <span style="font-size: 18px; font-weight: bold;">历史最高价折扣系统</span>
                    </div>
                    <div class="card-content">
                        上市至今全部前复权最高价计算 · 周期股十年均价修正
                    </div>
                </div>
                <svg id="anchor-arrow" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            
            <div id="anchor-detail" class="detail">
                <div class="anchor-grid">
                    <div class="anchor-box">
                        <div class="anchor-label">输入历史最高价</div>
                        <input type="number" id="highPrice" value="100" oninput="calc()" onclick="event.stopPropagation()">
                    </div>
                    <div class="anchor-box red">
                        <div class="anchor-label">L10 斩杀线 (4折)</div>
                        <div id="killPrice" class="anchor-value red">40.00</div>
                    </div>
                    <div class="anchor-box green">
                        <div class="anchor-label">满分锚点 (2.5折)</div>
                        <div id="perfectPrice" class="anchor-value green">25.00</div>
                    </div>
                    <div class="anchor-box blue">
                        <div class="anchor-label">周期股修正价</div>
                        <div id="cyclePrice" class="anchor-value blue">25.00</div>
                    </div>
                </div>
                <div style="margin-top: 15px; font-size: 12px; color: #666;">
                    <strong style="color: #ffaa00;">周期识别：</strong>对于煤炭/有色/钢铁等行业，若商品价格处于10年90%分位以上，即使股价2.5折也标记为【周期顶点陷阱】，不得满分。
                </div>
            </div>
        </div>

        <!-- L1-L3 -->
        <div class="section-title">
            <span>十层剔骨筛选阵</span>
            <span class="small">点击卡片展开详情</span>
        </div>

        <div class="card kill" onclick="toggle('d1', 'a1')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag">L1-L3</span>
                        <span style="font-size: 16px; font-weight: bold;">基础斩杀层</span>
                        <span class="badge badge-kill">刚性斩杀</span>
                    </div>
                    <div class="card-content">
                        ST股 / 次新股(&lt;1年) / 重大违规 / 日均成交&lt;8000万 / PE≤0或&gt;50 / PB&gt;3
                    </div>
                </div>
                <svg id="a1" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d1" class="detail">
                <div class="grid-2">
                    <div>
                        <strong style="color: #ff6b6b;">L1 基础过滤</strong><br>
                        ST/*ST标识、上市不满1年、近30日重大违规公告、黑名单历史记录
                    </div>
                    <div>
                        <strong style="color: #ff6b6b;">L2 流动性斩杀</strong><br>
                        近20日日均成交额&lt;8000万（战时降至5000万），伪流动性检测（振幅/换手率&gt;5%）
                    </div>
                    <div style="grid-column: 1 / -1;">
                        <strong style="color: #ff6b6b;">L3 估值斩杀</strong><br>
                        PE≤0或&gt;50，PB&gt;3（银行保险券商放宽至&gt;1.5），无估值数据按行业90分位保守处理
                    </div>
                </div>
            </div>
        </div>

        <!-- L4 -->
        <div class="card kill" onclick="toggle('d4', 'a4')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag red">L4</span>
                        <span style="font-size: 16px; font-weight: bold; color: #ff6b6b;">业绩斩杀（强化版）</span>
                        <span class="badge badge-kill">财务僵尸识别</span>
                    </div>
                    <div class="card-content" style="color: #ccc;">
                        TTM净利润 &lt; 0 <span style="color: #ff0040;">且</span> 连续2季亏损 <span style="color: #ff0040;">且</span> 扣非净利润 &lt; 0
                    </div>
                    <div class="highlight red">
                        斩杀情形：非经常性损益 &gt; 0（卖资产保壳，主营业务已废，纸面富贵）
                    </div>
                </div>
                <svg id="a4" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d4" class="detail">
                <strong style="color: #ff6b6b;">扣非净利润连续2季负增长且加速：</strong>直接斩杀<br>
                <strong style="color: #ff6b6b;">现金利润比：</strong>经营现金流净额/净利润 &lt; 0.5，标记为纸面富贵，降低业绩权重<br><br>
                <strong style="color: #888;">数据铁律：</strong>必须使用财报"扣除非经常性损益后净利润"原值，禁止倒推估算。找不到数据视为高风险，剔除。
            </div>
        </div>

        <!-- L5-L7 -->
        <div class="card kill" onclick="toggle('d7', 'a7')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag">L5-L7</span>
                        <span style="font-size: 16px; font-weight: bold;">筹码 / 板块 / 涨幅斩杀</span>
                        <span class="badge badge-kill">趋势与结构</span>
                    </div>
                    <div class="card-content">
                        套牢盘 &gt; 55% / 90日跌幅 &lt; -25% / 20日涨幅 &gt; 30% / 板块指数破年线
                    </div>
                </div>
                <svg id="a7" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d7" class="detail">
                <div class="highlight">
                    <strong style="color: #ffaa00;">L6 战时豁免条款（V5.2新增）：</strong><br>
                    若行业指数90日跌幅&lt;-30%（超卖）且该行业无大规模资产出售公告（未自断手臂），则豁免L6斩杀，标记为【困境反转候选】，可进入评分但总分扣10分。
                </div>
                <div style="margin-top: 10px;">
                    <strong>L5 筹码结构：</strong>套牢盘&gt;55%直接斩杀，引入筹码收敛度指标<br>
                    <strong>L6 板块周期：</strong>90日跌幅&lt;-25%，或行业指数跌破年线且斜率向下<br>
                    <strong>L7 近期涨幅：</strong>20日涨幅&gt;30%或未企稳（近5日振幅&gt;10%或3日收盘&lt;20日线）
                </div>
            </div>
        </div>

        <!-- L8 -->
        <div class="card kill" style="border: 2px solid rgba(255,0,64,0.3);" onclick="toggle('d8', 'a8')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag red">L8</span>
                        <span style="font-size: 18px; font-weight: bold; color: #ff6b6b;">月线趋势斩杀（刚性但可豁免）</span>
                        <span style="display: inline-block; width: 8px; height: 8px; background: #ff0040; border-radius: 50%; animation: pulse 2s infinite;"></span>
                    </div>
                    
                    <div class="grid-2" style="margin: 10px 0;">
                        <div class="highlight green">
                            <strong style="color: #00ff88;">通过条件（满足其一）</strong><br>
                            • 月K线标准底分型确认<br>
                            • 5/10/20月均线多头排列
                        </div>
                        <div class="highlight red">
                            <strong style="color: #ff6b6b;">斩杀情形（满足其一即砍）</strong><br>
                            • 月线MACD死叉且绿柱扩大<br>
                            • 下降通道（高低点下移）<br>
                            • 月线顶分型确认
                        </div>
                    </div>

                    <div class="highlight blue">
                        <strong style="color: #00d4ff;">⚡ 周线豁免通道（V5.2新增，解决踏空）：</strong><br>
                        若周线同时满足：KDJ(9,3,3)&lt;20金叉 + MACD底背离 + 周成交量&gt;前5周均值×1.5倍，可提前解锁L8限制，但月线维度得分封顶15分（满分40）。
                    </div>
                </div>
                <svg id="a8" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d8" class="detail">
                目的：避免接趋势向下的刀，必须确认月线级别转势。周线豁免允许在V型反转初期介入，但降低权重控制仓位，防止假突破。
            </div>
        </div>

        <!-- L9 -->
        <div class="card warn" style="border: 2px solid rgba(255,170,0,0.3);" onclick="toggle('d9', 'a9')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag orange">L9</span>
                        <span style="font-size: 18px; font-weight: bold; color: #ffaa00;">资产质量斩杀 → 改为【风险积分制】</span>
                    </div>
                    
                    <div style="margin: 10px 0; display: flex; flex-direction: column; gap: 8px;">
                        <div style="display: flex; justify-content: space-between; background: #0f0f0f; padding: 10px; border-radius: 4px; border: 1px solid #333;">
                            <span>非经常性损益/净利润 ∈ (50%, 100%]</span>
                            <strong style="color: #ffaa00;">扣 15 分</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; background: #0f0f0f; padding: 10px; border-radius: 4px; border: 1px solid #333;">
                            <span>非经常性损益/净利润 &gt; 100%（完全靠外快）</span>
                            <strong style="color: #ffaa00;">扣 30 分</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; background: rgba(255,0,64,0.1); padding: 10px; border-radius: 4px; border: 1px solid rgba(255,0,64,0.3);">
                            <span style="color: #ff6b6b;">出售核心资产且无可替代主业</span>
                            <strong style="color: #ff0040;">直接斩杀</strong>
                        </div>
                        <div style="display: flex; justify-content: space-between; background: #0f0f0f; padding: 10px; border-radius: 4px; border: 1px solid #333;">
                            <span>扣非净利润连续2季负增长且加速</span>
                            <strong style="color: #ffaa00;">扣 20 分</strong>
                        </div>
                    </div>

                    <div class="highlight">
                        <strong style="color: #ffaa00;">新斩杀条件：</strong>累计扣分 ≥ 40分 且 总分 &lt; 60分。允许"瑕疵优质股"存在（如暂时卖房产续命但主业稳健），避免样本过度枯竭。
                    </div>
                </div>
                <svg id="a9" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d9" class="detail">
                目的：从"一罪即斩"改为"累犯重罚"，解决样本过度枯竭问题，同时识别真财务诡计。出售核心资产且无可替代主业者直接斩杀（断臂求生，未来无以为继）。
            </div>
        </div>

        <!-- L10 -->
        <div class="card pass" style="border: 2px solid rgba(0,255,136,0.3);" onclick="toggle('d10', 'a10')">
            <div class="card-header">
                <div style="flex: 1;">
                    <div class="card-title">
                        <span class="tag green">L10</span>
                        <span style="font-size: 18px; font-weight: bold; color: #00ff88;">深度折扣门槛</span>
                        <span class="badge badge-pass">进入评分层</span>
                    </div>
                    <div style="margin-top: 10px; display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div>
                            <div style="margin-bottom: 5px;"><span style="color: #666;">常规通过线：</span> 当前价 ≤ 历史最高价 × <strong style="color: #00ff88;">40%</strong></div>
                            <div><span style="color: #666;">满分基准线：</span> 当前价 ≤ 历史最高价 × <strong style="color: #00ff88;">25%</strong></div>
                        </div>
                        <div class="highlight blue" style="margin: 0;">
                            <strong style="color: #00d4ff; font-size: 12px;">周期股修正（V5.2）：</strong><br>
                            <span style="font-size: 11px;">锚点 = min(历史最高×25%, 十年均价×60%)<br>
                            商品价格10年90%分位以上标记【周期顶点陷阱】</span>
                        </div>
                    </div>
                </div>
                <svg id="a10" class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 9l6 6 6-6"/>
                </svg>
            </div>
            <div id="d10" class="detail">
                硬性门槛：当前价必须低于历史最高价4折方可进入评分层，2.5折时折扣维度得满分25分。周期股采用十年均价修正，防止周期顶点误判。
            </div>
        </div>

        <!-- Scoring System -->
        <div class="section-title">
            <span>八维评分层</span>
            <span class="small">六硬核 + 二容忍 + 负分惩罚 · 满分130分</span>
        </div>

        <div class="score-grid">
            <div>
                <div style="color: #ff0040; font-weight: bold; margin-bottom: 10px; font-size: 14px;">硬性维度（不可为0分，否则强制剔除）</div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">1. 折扣得分</div>
                        <div style="font-size: 12px; color: #666;">2.5折=25分, 4折=0分</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">2. 筹码结构</div>
                        <div style="font-size: 12px; color: #666;">套牢盘 + 集中度</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">3. 近期涨幅</div>
                        <div style="font-size: 12px; color: #666;">20日涨跌幅区间</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">4. 业绩质量</div>
                        <div style="font-size: 12px; color: #666;">TTM利润 + 增速 + 现金比</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">5. 估值水平</div>
                        <div style="font-size: 12px; color: #666;">PE/PB分档评分</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
                
                <div class="score-item">
                    <div>
                        <div style="font-weight: bold;">8. 月线技术</div>
                        <div style="font-size: 12px; color: #666;">底分型 + 倍量 + 共振</div>
                    </div>
                    <span class="must">必须 &gt; 0</span>
                </div>
            </div>

            <div>
                <div style="color: #ffaa00; font-weight: bold; margin-bottom: 10px; font-size: 14px;">容忍维度（可为0分或负分）</div>
                
                <div class="score-item" style="border-left: 3px solid #ffaa00;">
                    <div style="flex: 1;">
                        <div style="font-weight: bold; margin-bottom: 8px;">6. 股东数变化 (-15分 至 +10分)</div>
                        <div style="font-size: 12px; color: #888; line-height: 1.8;">
                            <div style="display: flex; justify-content: space-between;"><span>减少 &gt; 15%</span><span style="color: #00ff88;">+10分</span></div>
                            <div style="display: flex; justify-content: space-between;"><span>增加 &gt; 30%（主力跑路）</span><span style="color: #ff0040; font-weight: bold;">-15分</span></div>
                        </div>
                    </div>
                </div>
                
                <div class="score-item" style="border-left: 3px solid #ffaa00;">
                    <div style="flex: 1;">
                        <div style="font-weight: bold; margin-bottom: 8px;">7. 回购行为 (-5分 至 +5分)</div>
                        <div style="font-size: 12px; color: #888; line-height: 1.8;">
                            <div style="display: flex; justify-content: space-between;"><span>回购注销</span><span style="color: #00ff88;">+5分</span></div>
                            <div style="display: flex; justify-content: space-between;"><span>用于股权激励</span><span style="color: #ffaa00;">-3分</span></div>
                            <div style="display: flex; justify-content: space-between;"><span>忽悠式回购</span><span style="color: #ff0040; font-weight: bold;">-5分</span></div>
                        </div>
                    </div>
                </div>

                <div style="background: #0f0f0f; border: 1px solid #333; border-radius: 8px; padding: 20px; margin-top: 15px; text-align: center;">
                    <div style="font-size: 14px; color: #666; margin-bottom: 5px;">总分</div>
                    <div style="font-size: 36px; font-weight: bold; color: #00d4ff;">130</div>
                    <div style="font-size: 12px; color: #666; margin-top: 5px;">硬性维度1/2/3/4/5/8不可为0分</div>
                </div>
            </div>
        </div>

        <!-- Output Classification -->
        <div class="section-title">输出分级</div>
        
        <div class="grid-3">
            <div class="output-card green">
                <div class="output-title">
                    <span style="color: #00ff88;">龙头仓位 TOP3</span>
                    <span style="font-size: 12px; color: #00ff88; opacity: 0.7;">重仓</span>
                </div>
                <div style="font-size: 13px; color: #aaa; line-height: 1.8;">
                    • 当前价 ≤ 2.5折（满分锚点）<br>
                    • 月/周/日三周期共振<br>
                    • 无L9红灯或周线豁免确认<br>
                    • 总分 ≥ 100分
                </div>
            </div>
            
            <div class="output-card blue">
                <div class="output-title">
                    <span style="color: #00d4ff;">标准仓位 TOP4-10</span>
                    <span style="font-size: 12px; color: #00d4ff; opacity: 0.7;">中仓</span>
                </div>
                <div style="font-size: 13px; color: #aaa; line-height: 1.8;">
                    • 当前价 2.5折-3折（25%-30%）<br>
                    • 月线底分型确认（或周线豁免）<br>
                    • L9累计扣分 &lt; 40分<br>
                    • 总分 ≥ 80分
                </div>
            </div>
            
            <div class="output-card orange">
                <div class="output-title">
                    <span style="color: #ffaa00;">观察池</span>
                    <span style="font-size: 12px; color: #ffaa00; opacity: 0.7;">轻仓/等待</span>
                </div>
                <div style="font-size: 13px; color: #aaa; line-height: 1.8;">
                    • 通过L1-L10但无周期共振<br>
                    • 月线底分型但周线KDJ仍&gt;50<br>
                    • L9有红灯但价格&lt;2折（极限超跌）<br>
                    • 标记【困境反转】或【周期陷阱】
                </div>
            </div>
        </div>

        <!-- War Mode Notice -->
        <div id="war-notice" class="notice">
            <div style="font-weight: bold; color: #00d4ff; margin-bottom: 10px; display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 20px;">⚡</span> 战时模式已激活（V5.2特别状态）
            </div>
            <div style="font-size: 13px; color: #888; line-height: 1.8; display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                <div>• L2流动性：8000万 → 5000万</div>
                <div>• L6板块斩杀：暂停（豁免困境行业）</div>
                <div>• L9资产质量：改为累计扣分制（-40分才斩杀）</div>
                <div>• 周期股锚点：启用十年均价修正</div>
                <div>• 样本目标：从&lt;5%提升至15-20%</div>
                <div>• 风险容忍：允许更多左侧陷阱存在</div>
            </div>
        </div>

        <footer>
            <div style="margin-bottom: 8px; font-weight: bold; color: #888;">八维量化雷达 V5.2 · 十层剔骨阵 · 数据零魔改协议</div>
            <div>生存与进攻平衡版 | 周线豁免通道 | 财务诡计过滤 | 周期陷阱识别</div>
        </footer>

    </div>

    <script>
        function toggle(detailId, arrowId) {
            const detail = document.getElementById(detailId);
            const arrow = document.getElementById(arrowId);
            
            if (detail.classList.contains('show')) {
                detail.classList.remove('show');
                arrow.classList.remove('rotate');
            } else {
                // 关闭其他的（可选，如果要手风琴效果就取消注释）
                // document.querySelectorAll('.detail').forEach(d => d.classList.remove('show'));
                // document.querySelectorAll('.arrow').forEach(a => a.classList.remove('rotate'));
                
                detail.classList.add('show');
                arrow.classList.add('rotate');
            }
        }
        
        function calc() {
            const high = parseFloat(document.getElementById('highPrice').value) || 100;
            document.getElementById('killPrice').textContent = (high * 0.4).toFixed(2);
            document.getElementById('perfectPrice').textContent = (high * 0.25).toFixed(2);
            document.getElementById('cyclePrice').textContent = (high * 0.25).toFixed(2);
        }
        
        function setMode(mode) {
            const btns = document.querySelectorAll('.mode-btn');
            const notice = document.getElementById('war-notice');
            
            if (mode === 'normal') {
                btns[0].classList.add('active');
                btns[0].style.color = '#00d4ff';
                btns[1].classList.remove('active');
                btns[1].style.color = '#888';
                notice.classList.remove('show');
            } else {
                btns[1].classList.add('active');
                btns[1].style.color = '#00d4ff';
                btns[0].classList.remove('active');
                btns[0].style.color = '#888';
                notice.classList.add('show');
            }
        }
        
        // 初始化
        calc();
        
        // 脉冲动画
        const style = document.createElement('style');
        style.textContent = `
            @keyframes pulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.3; }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
